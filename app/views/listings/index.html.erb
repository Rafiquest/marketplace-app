<h2>All Listings</h2>

<%= form_with url: listings_path, method: :get, local: true do %>
  <%= select_tag :category, options_for_select(Listing::CATEGORIES.map { |c| [c.titleize, c] }, params[:category]), prompt: "Filter by Category" %>

  <%= select_tag :sort, options_for_select([["Price Low to High", "asc"], ["Price High to Low", "desc"]], params[:sort]), prompt: "Sort by Price" %>

  <%= text_field_tag :search, params[:search], placeholder: "Search listings..." %>

  <%= submit_tag "Apply", class: "btn btn-primary" %>
<% end %>

<hr>

<% @listings.each do |listing| %>
  <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px;">
    <h3><%= listing.name %></h3>
    <p><strong>Price:</strong> ₹<%= listing.price %></p>
    <p><strong>Category:</strong> 
      <%= listing.category ? listing.category.to_s.titleize : "Uncategorized" %>
    </p>

    <p><%= listing.description %></p>

    <% if listing.image.attached? %>
      <%= image_tag listing.image, width: 200 %>
    <% end %>

    <!-- ✅ Add this button -->
    <%= link_to "View Details", listing_path(listing), class: "btn btn-info" %>
  </div>
<% end %>

