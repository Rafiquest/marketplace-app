<style>
  .navbar {
    background-color: #222;
    padding: 10px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: sans-serif;
    color: #fff;
  }

  .nav-left {
    font-size: 14px;
  }

  .nav-right {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .nav-link,
  .logout-button button {
    background-color: #444;
    color: white;
    border: none;
    padding: 6px 10px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 13px;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .nav-link:hover,
  .logout-button button:hover {
    background-color: #666;
  }

  .logout-button {
    margin: 0;
  }
</style>

<div class="navbar">
  <% if user_signed_in? %>
    <div class="nav-left">
      <%= current_user.role.capitalize %>: <strong><%= current_user.email.split('@').first %></strong>
    </div>

    <div class="nav-right">
      <% if current_user.seller? %>
        <%= link_to '➕ New Listing', new_listing_path, class: 'nav-link' %>
        <%= link_to '📋 My Listings', my_listings_path, class: 'nav-link' %>
        <%= link_to '📨 Buyer Messages', sellers_messages_path, class: 'nav-link' %>
      <% elsif current_user.buyer? %>
        <%= link_to '🏠 Home', buyers_index_path, class: 'nav-link' %>
        <%= link_to '🔍 Browse Listings', listings_path, class: 'nav-link' %>
      <% end %>

      <%= button_to '🚪 Logout', destroy_user_session_path, method: :delete, class: 'logout-button' %>
    </div>
  <% else %>
    <div class="nav-right">
      <%= link_to '🔐 Login', new_user_session_path, class: 'nav-link' %>
      <%= link_to '📝 Sign Up', new_user_registration_path, class: 'nav-link' %>
    </div>
  <% end %>
</div>
